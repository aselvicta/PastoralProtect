# Copy to .env (never commit .env). Must match backend STORACHA_UPLOADER_SECRET.
STORACHA_UPLOADER_SECRET=your-long-random-string
PORT=8788

# Optional: pin uploads to a specific Storacha space (did:key:...). Leave empty to use current space.
# STORACHA_SPACE_DID=

# Optional: w3up client profile name (default w3up-client).
# STORACHA_PROFILE=w3up-client
