# --- Secrets & environment (never commit real values) ---
# Ignore all env files; allow only *.example templates to stay tracked.
.env
.env.*
!.env.example
!**/.env.example
!.env.*.example
!**/.env.*.example

# Next.js local overrides (explicit; safe if .env.* rules change)
.env.local
.env.development.local
.env.test.local
.env.production.local

