# --- Core (local demo) ---
# SQLite = zero setup for GitHub clones. For production Postgres, see docs/SETUP.md and docs/FUTURE_WORK.md
DATABASE_URL=sqlite:///./pastoral_protect.db
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/pastoral_protect
PORT=8000

# --- Optional: Base Sepolia + PastoralProtectPool (leave empty for demo without chain) ---
BASE_RPC_URL=
PRIVATE_KEY=
# Optional: separate wallet for admin-only txs; if empty, PRIVATE_KEY is used for admin + oracle signing paths
ADMIN_PRIVATE_KEY=
CONTRACT_ADDRESS=
CONTRACT_ARTIFACT_PATH=../contracts/artifacts/contracts/PastoralProtectPool.sol/PastoralProtectPool.json

ORACLE_SECRET=dev-oracle-secret
ADMIN_API_KEY=dev-admin-key

JWT_SECRET=change-me-in-production-pastoralprotect
JWT_EXPIRE_MINUTES=480

# --- Storage: mock by default; real IPFS optional ---
# Leave all three empty → in-memory mock CIDs (enough for every cloner; no Storacha install).
# Storacha (recommended real path): run storacha-uploader + npm run login — see storacha-uploader/README.md
STORACHA_UPLOADER_URL=
STORACHA_UPLOADER_SECRET=
# If true (default), Storacha bridge 503 (e.g. run npm run login in storacha-uploader) falls back to mock CIDs instead of failing oracle
STORACHA_FALLBACK_MOCK_ON_ERROR=true
# Legacy HTTP Bearer upload (only if your provider still issues a token)
WEB3_STORAGE_TOKEN=
FILECOIN_UPLOAD_URL=https://api.web3.storage/upload
IPFS_GATEWAY_BASE=https://w3s.link/ipfs

# Comma-separated browser origins; leave empty for localhost/127.0.0.1 ports 3000–3001
# CORS_ALLOWED_ORIGINS=

# If true, POST /api/demo/run works without JWT (kiosk). Set false for any public deployment.
DEMO_PUBLIC_ACCESS=true

# Fake provider pause per payout (ms). Many policies in one zone = sum of delays. Use 0 for fast talks.
MOCK_PAYMENT_DELAY_MS=150
PAYOUT_PER_HEAD=1000
CHAIN_ENROLL_VALUE_WEI=1000000000000000
